<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="TrellisLocal" value="C:\GitHub\Trellis\local-feed" />
    <add key="TrellisAlpha" value="https://nuget.pkg.github.com/xavierjohn/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="Trellis.ServiceLevelIndicators*" />
    </packageSource>
    <packageSource key="TrellisLocal">
      <package pattern="Trellis.*" />
    </packageSource>
    <packageSource key="TrellisAlpha">
      <package pattern="Trellis.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>